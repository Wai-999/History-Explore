---
interface Props {
  value: string;
  label: string;
  note?: string;
}
const { value, label, note } = Astro.props;
---
<div class="card p-5">
  <p class="font-display text-3xl font-semibold text-green-800 sm:text-4xl">{value}</p>
  <p class="mt-1 text-sm font-medium text-espresso">{label}</p>
  {note && <p class="mt-1 text-xs text-espresso-soft/70">{note}</p>}
</div>
